$env:HOST = "127.0.0.1"
$env:PORT = "3000"

$env:WHATSAPP_VERIFY_TOKEN = "replace-with-your-verify-token"

$env:WHATSAPP_DELIVERY_MODE = "skipped"
$env:WHATSAPP_STORE_MODE = "sqlite"
$env:WHATSAPP_SQLITE_PATH = ".\.runtime-data\whatsapp-live-pilot.sqlite"

$env:WHATSAPP_BUSINESS_CONTEXT_ID = "customer-service-core-v2"
$env:WHATSAPP_SESSION_ID_PREFIX = "whatsapp-session"

# Required for operational HTTP endpoints:
# - GET /whatsapp/handoffs
# - POST /whatsapp/handoffs/:handoffId/close
$env:OPS_API_TOKEN = "replace-with-ops-api-token"

# Optional but recommended for live Meta/WhatsApp webhook POST validation.
# When set, POST /webhooks/whatsapp requires x-hub-signature-256.
# $env:WHATSAPP_APP_SECRET = "replace-with-meta-app-secret"

# Required only when WHATSAPP_DELIVERY_MODE = "http"
# $env:WHATSAPP_API_VERSION = "v23.0"
# $env:WHATSAPP_PHONE_NUMBER_ID = "replace-with-phone-number-id"
# $env:WHATSAPP_ACCESS_TOKEN = "replace-with-access-token"