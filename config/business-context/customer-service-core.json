      "stage": "collect-product-name",
      "status": "missing-entity",
      "messageTemplate": "Please provide the coverage option name so I can help you."
    },
    {
      "responseId": "consult-product-resolved",
      "intentId": "consult-product",
      "stage": "resolve-product",
      "status": "resolved",
      "messageTemplate": "The coverage option information has been retrieved."
    },
    {
      "responseId": "consult-price-missing-product-name",
      "intentId": "consult-price",
      "stage": "collect-product-name",
      "status": "missing-entity",
      "messageTemplate": "Please provide the coverage option name so I can check the estimated premium."
    },
    {
      "responseId": "consult-price-resolved",
      "intentId": "consult-price",
      "stage": "resolve-price",
      "status": "resolved",
      "messageTemplate": "The estimated premium information has been retrieved."
    },
    {
      "responseId": "consult-availability-missing-product-name",
      "intentId": "consult-availability",
      "stage": "collect-product-name",
      "status": "missing-entity",
      "messageTemplate": "Please provide the coverage option name so I can check availability."
    },
    {
      "responseId": "consult-availability-resolved",
      "intentId": "consult-availability",
      "stage": "resolve-availability",
      "status": "resolved",
      "messageTemplate": "The coverage option availability information has been retrieved."
    },
    {
      "responseId": "request-quote-resolved",
      "intentId": "request-quote",
      "stage": "resolve-quote-intake",
      "status": "resolved",
      "messageTemplate": "The quote intake workflow has been started."
    },
    {
      "responseId": "consult-renewal-status-resolved",
      "intentId": "consult-renewal-status",
      "stage": "resolve-renewal-status",
      "status": "resolved",
      "messageTemplate": "The renewal status information has been retrieved."
    },
    {
      "responseId": "consult-order-status-missing-order-id",
      "intentId": "consult-order-status",
      "stage": "collect-order-id",
      "status": "missing-entity",
      "messageTemplate": "Please provide your request ID so I can review the status."
    },
    {
      "responseId": "consult-order-status-resolved",
      "intentId": "consult-order-status",
      "stage": "resolve-order-status",
      "status": "resolved",
      "messageTemplate": "Your request status has been retrieved."
    },
    {
      "responseId": "consult-policy-missing-policy-topic",
      "intentId": "consult-policy",
      "stage": "collect-policy-topic",
      "status": "missing-entity",
      "messageTemplate": "Please provide the policy topic so I can help you."
    },
    {
      "responseId": "consult-policy-resolved",
      "intentId": "consult-policy",
      "stage": "resolve-policy",
      "status": "resolved",
      "messageTemplate": "The policy servicing information has been retrieved."
    },
    {
      "responseId": "handoff-requested",
      "intentId": "request-human-handoff",
      "stage": "handoff-requested",
      "status": "handoff",
      "messageTemplate": "Your conversation will be transferred to a licensed broker specialist."
    },
    {
      "responseId": "conversation-closed",
      "intentId": "close-conversation",
      "stage": "done",
      "status": "closed",
      "messageTemplate": "Your conversation has been closed."
    }
  ],
  "handoffRules": [
    {
      "ruleId": "explicit-human-request",
      "whenIntentIds": ["request-human-handoff"],
      "requiresHuman": true,
      "queue": "licensed-broker"
    }
  ],
  "tonePolicy": {
    "toneId": "default-neutral",
    "style": "neutral",
    "brevity": "medium"
  },
  "sessionPolicy": {
    "inactivityTimeoutMinutes": 30,
    "allowResume": true,
    "maxTurnsBeforeClosure": 100
  }
}