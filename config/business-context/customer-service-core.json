{
  "contextId": "customer-service-core-v2",
  "domain": "customer-service",
  "businessName": "Generic Customer Service",
  "supportedIntents": [
    {
      "intentId": "consult-product",
      "description": "Consult information about a product.",
      "requiredEntities": ["productName"],
      "optionalEntities": ["sku"],
      "workflowId": "product-consultation-flow"
    },
    {
      "intentId": "consult-price",
      "description": "Consult the price of a product.",
      "requiredEntities": ["productName"],
      "optionalEntities": ["sku"],
      "workflowId": "price-consultation-flow"
    },
    {
      "intentId": "consult-availability",
      "description": "Consult the availability of a product.",
      "requiredEntities": ["productName"],
      "optionalEntities": ["sku"],
      "workflowId": "availability-flow"
    },
    {
      "intentId": "consult-order-status",
      "description": "Consult the status of an order.",
      "requiredEntities": ["orderId"],
      "optionalEntities": [],
      "workflowId": "order-status-flow"
    },
    {
      "intentId": "consult-policy",
      "description": "Consult a business policy topic.",
      "requiredEntities": ["policyTopic"],
      "optionalEntities": [],
      "workflowId": "policy-consultation-flow"
    },
    {
      "intentId": "request-human-handoff",
      "description": "Request transfer to a human agent.",
      "requiredEntities": [],
      "optionalEntities": [],
      "workflowId": "handoff-flow"
    },
    {
      "intentId": "close-conversation",
      "description": "Close the current conversation.",
      "requiredEntities": [],
      "optionalEntities": [],
      "workflowId": "closure-flow"
    }
  ],
  "entitySchema": [
    {
      "entityId": "productName",
      "entityType": "string",
      "required": false
    },
    {
      "entityId": "sku",
      "entityType": "string",
      "required": false
    },
    {
      "entityId": "orderId",
      "entityType": "string",
      "required": false
    },
    {
      "entityId": "policyTopic",
      "entityType": "string",
      "required": false
    }
  ],
  "workflowRules": [
    {
      "workflowId": "product-consultation-flow",
      "stages": ["start", "collect-product-name", "resolve-product", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "price-consultation-flow",
      "stages": ["start", "collect-product-name", "resolve-price", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "availability-flow",
      "stages": ["start", "collect-product-name", "resolve-availability", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "order-status-flow",
      "stages": ["start", "collect-order-id", "resolve-order-status", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "policy-consultation-flow",
      "stages": ["start", "collect-policy-topic", "resolve-policy", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "handoff-flow",
      "stages": ["start", "handoff-requested", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "closure-flow",
      "stages": ["start", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    }
  ],
  "canonicalResponses": [
    {
      "responseId": "consult-product-missing-product-name",
      "intentId": "consult-product",
      "stage": "collect-product-name",
      "status": "missing-entity",
      "messageTemplate": "Please provide the product name so I can help you."
    },
    {
      "responseId": "consult-product-resolved",
      "intentId": "consult-product",
      "stage": "resolve-product",
      "status": "resolved",
      "messageTemplate": "The product information has been retrieved."
    },
    {
      "responseId": "consult-price-missing-product-name",
      "intentId": "consult-price",
      "stage": "collect-product-name",
      "status": "missing-entity",
      "messageTemplate": "Please provide the product name so I can check the price."
    },
    {
      "responseId": "consult-price-resolved",
      "intentId": "consult-price",
      "stage": "resolve-price",
      "status": "resolved",
      "messageTemplate": "The product price has been retrieved."
    },
    {
      "responseId": "consult-availability-missing-product-name",
      "intentId": "consult-availability",
      "stage": "collect-product-name",
      "status": "missing-entity",
      "messageTemplate": "Please provide the product name so I can check availability."
    },
    {
      "responseId": "consult-availability-resolved",
      "intentId": "consult-availability",
      "stage": "resolve-availability",
      "status": "resolved",
      "messageTemplate": "The product availability has been retrieved."
    },
    {
      "responseId": "consult-order-status-missing-order-id",
      "intentId": "consult-order-status",
      "stage": "collect-order-id",
      "status": "missing-entity",
      "messageTemplate": "Please provide your order ID so I can review the order status."
    },
    {
      "responseId": "consult-order-status-resolved",
      "intentId": "consult-order-status",
      "stage": "resolve-order-status",
      "status": "resolved",
      "messageTemplate": "Your order status has been retrieved."
    },
    {
      "responseId": "consult-policy-missing-policy-topic",
      "intentId": "consult-policy",
      "stage": "collect-policy-topic",
      "status": "missing-entity",
      "messageTemplate": "Please provide the policy topic so I can help you."
    },
    {
      "responseId": "consult-policy-resolved",
      "intentId": "consult-policy",
      "stage": "resolve-policy",
      "status": "resolved",
      "messageTemplate": "The policy information has been retrieved."
    },
    {
      "responseId": "handoff-requested",
      "intentId": "request-human-handoff",
      "stage": "handoff-requested",
      "status": "handoff",
      "messageTemplate": "Your conversation will be transferred to a human agent."
    },
    {
      "responseId": "conversation-closed",
      "intentId": "close-conversation",
      "stage": "done",
      "status": "closed",
      "messageTemplate": "Your conversation has been closed."
    }
  ],
  "handoffRules": [
    {
      "ruleId": "explicit-human-request",
      "whenIntentIds": ["request-human-handoff"],
      "requiresHuman": true,
      "queue": "general"
    }
  ],
  "tonePolicy": {
    "toneId": "default-neutral",
    "style": "neutral",
    "brevity": "medium"
  },
  "sessionPolicy": {
    "inactivityTimeoutMinutes": 30,
    "allowResume": true,
    "maxTurnsBeforeClosure": 100
  }
}