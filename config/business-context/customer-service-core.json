{
  "contextId": "customer-service-core-v2",
  "domain": "insurance-brokerage",
  "businessName": "Northwind Insurance Brokers",
  "supportedIntents": [
    {
      "intentId": "consult-product",
      "description": "Consult information about an insurance coverage option.",
      "requiredEntities": ["productName"],
      "optionalEntities": ["sku"],
      "workflowId": "product-consultation-flow"
    },
    {
      "intentId": "consult-price",
      "description": "Consult the estimated premium for an insurance coverage option.",
      "requiredEntities": ["productName"],
      "optionalEntities": ["sku"],
      "workflowId": "price-consultation-flow"
    },
    {
      "intentId": "consult-availability",
      "description": "Consult the current availability or eligibility status of an insurance coverage option.",
      "requiredEntities": ["productName"],
      "optionalEntities": ["sku"],
      "workflowId": "availability-flow"
    },
    {
      "intentId": "request-quote",
      "description": "Start an insurance quote intake workflow for a customer.",
      "requiredEntities": [],
      "optionalEntities": ["productName"],
      "workflowId": "quote-intake-flow"
    },
    {
      "intentId": "consult-renewal-status",
      "description": "Consult the current renewal status for an insurance policy or renewal case.",
      "requiredEntities": [],
      "optionalEntities": ["orderId", "productName"],
      "workflowId": "renewal-status-flow"
    },
    {
      "intentId": "consult-order-status",
      "description": "Consult the status of an insurance application or servicing request.",
      "requiredEntities": ["orderId"],
      "optionalEntities": [],
      "workflowId": "order-status-flow"
    },
    {
      "intentId": "consult-policy",
      "description": "Consult a policy servicing topic.",
      "requiredEntities": ["policyTopic"],
      "optionalEntities": [],
      "workflowId": "policy-consultation-flow"
    },
    {
      "intentId": "request-human-handoff",
      "description": "Request transfer to a licensed broker specialist.",
      "requiredEntities": [],
      "optionalEntities": [],
      "workflowId": "handoff-flow"
    },
    {
      "intentId": "close-conversation",
      "description": "Close the current conversation.",
      "requiredEntities": [],
      "optionalEntities": [],
      "workflowId": "closure-flow"
    }
  ],
  "entitySchema": [
    {
      "entityId": "productName",
      "entityType": "string",
      "required": false
    },
    {
      "entityId": "sku",
      "entityType": "string",
      "required": false
    },
    {
      "entityId": "orderId",
      "entityType": "string",
      "required": false
    },
    {
      "entityId": "policyTopic",
      "entityType": "string",
      "required": false
    }
  ],
  "workflowRules": [
    {
      "workflowId": "product-consultation-flow",
      "stages": ["start", "collect-product-name", "resolve-product", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "price-consultation-flow",
      "stages": ["start", "collect-product-name", "resolve-price", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "availability-flow",
      "stages": ["start", "collect-product-name", "resolve-availability", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "quote-intake-flow",
      "stages": ["start", "collect-quote-context", "resolve-quote-intake", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "renewal-status-flow",
      "stages": ["start", "collect-renewal-context", "resolve-renewal-status", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "order-status-flow",
      "stages": ["start", "collect-order-id", "resolve-order-status", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "policy-consultation-flow",
      "stages": ["start", "collect-policy-topic", "resolve-policy", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "handoff-flow",
      "stages": ["start", "handoff-requested", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    },
    {
      "workflowId": "closure-flow",
      "stages": ["start", "done"],
      "initialStage": "start",
      "terminalStages": ["done"]
    }
  ],
  "canonicalResponses": [
    {
      "responseId": "consult-product-missing-product-name",
